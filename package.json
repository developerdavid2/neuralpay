{
  "name": "neuralpay",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "apps/server/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "date-fns": "^4.1.0",
      "zod": "^4.1.13",
      "drizzle-orm": "^0.45.1",
      "typescript": "^6",
      "tsup": "6.6.3",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.5.5",
      "@types/express": "^5.0.1",
      "express": "^5.2.1",
      "morgan": "^1.10.1",
      "cors": "^2.8.6",
      "helmet": "^8.1.0",
      "lucide-react": "^0.546.0",
      "uploadthing": "7.7.2",
      "next-themes": "^0.4.6",
      "radix-ui": "latest",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "ioredis": "^5.11.1",
      "bullmq": "^5.79.2",
      "rate-limiter-flexible": "^11.2.0",
      "@trpc/client": "^11.16.0",
      "@polar-sh/better-auth": "^1.8.3",
      "@types/react": "^19.2.10",
      "@types/node": "^20",
      "@types/cors": "^2.8.19",
      "@types/morgan": "^1.9.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F api-gateway dev",
    "dev:all": "turbo dev",
    "dev:gateway": "turbo -F api-gateway dev",
    "dev:user": "turbo -F user-service dev",
    "dev:payment": "turbo -F payment-service dev",
    "dev:ai": "turbo -F ai-service dev",
    "dev:notification": "turbo -F notification-service dev",
    "dev:backend": "turbo -F api-gateway -F user-service -F payment-service -F ai-service -F notification-service dev",
    "health:check": "bun scripts/health-check.ts",
    "db:push": "turbo -F @neuralpay/db db:push",
    "db:studio": "turbo -F @neuralpay/db db:studio",
    "db:generate": "turbo -F @neuralpay/db db:generate",
    "db:migrate": "turbo -F @neuralpay/db db:migrate",
    "db:start": "turbo -F @neuralpay/db db:start",
    "db:watch": "turbo -F @neuralpay/db db:watch",
    "db:stop": "turbo -F @neuralpay/db db:stop",
    "db:down": "turbo -F @neuralpay/db db:down",
    "prepare": "husky"
  },
  "dependencies": {
    "@neuralpay/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@neuralpay/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": ""
  },
  "packageManager": "bun@1.3.11"
}
