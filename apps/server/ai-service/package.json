    "better-auth": "catalog:",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "^20.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "catalog:",
    "drizzle-orm": "catalog:",
