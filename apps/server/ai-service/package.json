{
  "name": "@neuralpay/ai-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./routers": {
      "default": "./src/routers/index.ts"
    },
    ".": {
      "default": "./src/index.ts"
    }
  },
  "main": "./src/app.ts",
  "scripts": {
    "dev": "PORT=4003 bun run --hot src/app.ts",
    "build": "tsup",
    "start": "node dist/app.js",
    "check-types": "tsc -b"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.41",
    "@neuralpay/auth": "workspace:*",
    "@neuralpay/db": "workspace:*",
    "@neuralpay/env": "workspace:*",
    "@neuralpay/types": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@trpc/server": "catalog:",
    "ai": "^6.0.203",
    "express": "catalog:",
    "zod": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@neuralpay/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/bun": "catalog:",
    "@types/express": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
