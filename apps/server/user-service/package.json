{
  "name": "@neuralpay/user-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./routers": {
      "default": "./src/routers/index.ts"
    },
    ".": {
      "default": "./src/main.ts"
    }
  },
  "scripts": {
    "dev": "PORT=4001 bun run --hot src/main.ts",
