{
  "name": "@neuralpay/user-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./routers": {
      "default": "./src/routers/index.ts"
    },
    ".": {
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "PORT=4001 bun run --hot src/app.ts",
    "build": "tsup",
    "start": "node dist/app.js",
    "check-types": "tsc -b"
  },
  "dependencies": {
    "@neuralpay/auth": "workspace:*",
    "@neuralpay/db": "workspace:*",
    "@neuralpay/env": "workspace:*",
    "@neuralpay/types": "workspace:*",
    "@neuralpay/file-upload": "workspace:*",
    "@neuralpay/config": "workspace:*",
    "@trpc/server": "catalog:",
    "axios": "^1.18.1",
    "better-auth": "catalog:",
    "country-state-city": "^3.2.1",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "uploadthing": "catalog:",
    "@uploadthing/shared": "7.1.8",
    "morgan": "catalog:",
    "cors": "catalog:",
    "helmet": "catalog:",
    "ua-parser-js": "^2.0.10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/morgan": "catalog:",
    "@types/cors": "catalog:",
    "typescript": "catalog:",
    "tsup": "catalog:"
  }
}
