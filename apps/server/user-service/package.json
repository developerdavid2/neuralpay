    "@neuralpay/env": "workspace:*",
    "@neuralpay/types": "workspace:*",
    "@neuralpay/file-upload": "workspace:*",
    "@trpc/server": "catalog:",
    "axios": "^1.18.1",
    "better-auth": "catalog:",
    "cors": "^2.8.6",
    "country-state-city": "^3.2.1",
    "drizzle-orm": "catalog:",
    "express": "catalog:",
    "uploadthing": "catalog:",
    "@uploadthing/shared": "7.1.8",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "ua-parser-js": "^2.0.10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.19",
    "@types/express": "catalog:",
    "@types/morgan": "^1.9.10",
