{
  "name": "api-gateway",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/main.ts --outfile server",
    "dev": "PORT=4000 bun run --hot src/main.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@neuralpay/api": "workspace:*",
    "@neuralpay/auth": "workspace:*",
    "@neuralpay/db": "workspace:*",
    "@neuralpay/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "express-http-proxy": "^2.1.2",
    "express-rate-limit": "^8.4.1",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.10.1",
    "winston": "^3.19.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@neuralpay/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "catalog:",
    "@types/express-http-proxy": "^1.6.7",
    "@types/ioredis": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
